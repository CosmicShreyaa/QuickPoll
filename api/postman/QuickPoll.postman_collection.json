{
  "info": {
    "name": "QuickPoll API",
    "_postman_id": "b6a1f7b0-6e6d-4a2a-9a9b-0f4c9a7c9a10",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:4000/api" },
    { "key": "token", "value": "" },
    { "key": "pollId", "value": "" }
  ],
  "item": [
    {
      "name": "Health check",
      "request": { "method": "GET", "url": "{{baseUrl}}/health" }
    },
    {
      "name": "Auth / Sign up",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 201) {",
              "  const body = pm.response.json();",
              "  pm.collectionVariables.set('token', body.token);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/auth/signup",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Ada Lovelace\",\n  \"email\": \"ada@example.com\",\n  \"password\": \"password123\"\n}"
        }
      }
    },
    {
      "name": "Auth / Sign in",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "  const body = pm.response.json();",
              "  pm.collectionVariables.set('token', body.token);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/auth/signin",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"ada@example.com\",\n  \"password\": \"password123\"\n}"
        }
      }
    },
    {
      "name": "Auth / Me",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/auth/me"
      }
    },
    {
      "name": "Polls / List",
      "request": { "method": "GET", "url": "{{baseUrl}}/polls" }
    },
    {
      "name": "Polls / Create",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 201) {",
              "  const body = pm.response.json();",
              "  pm.collectionVariables.set('pollId', body.id);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{baseUrl}}/polls",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"question\": \"What should we build next?\",\n  \"options\": [\"Dark mode\", \"Team workspaces\", \"AI suggestions\"]\n}"
        }
      }
    },
    {
      "name": "Polls / Get one",
      "request": { "method": "GET", "url": "{{baseUrl}}/polls/{{pollId}}" }
    },
    {
      "name": "Polls / Vote",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/polls/{{pollId}}/vote",
        "body": { "mode": "raw", "raw": "{\n  \"optionId\": \"a\"\n}" }
      }
    },
    {
      "name": "Polls / Delete",
      "request": {
        "method": "DELETE",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/polls/{{pollId}}"
      }
    }
  ]
}
